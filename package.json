{
  "name": "maias-monorepo",
  "private": true,
  "engines": {
    "node": "^20.19.4 || ^22.13.0 || ^24.3.0 || >=25.0.0"
  },
  "workspaces": [
    "packages/*",
    "MAIAS_browser"
  ],
  "scripts": {
    "build": "npm run build -w @maias/core && npm run build -w @maias/cli -w @maias/mcp",
    "link-tools": "npm link -w @maias/cli -w @maias/mcp",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  }
}
