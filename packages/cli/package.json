{
  "name": "@maias/cli",
  "version": "0.2.0",
  "description": "MAIAS command-line tools: maias validate, maias fmt, maias rename.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MAIAS-project/maias.git",
